BOT_TOKEN=put-your-telegram-token-here
GEMINI_API_KEY=put-your-gemini-key-here
# Модель Gemini, напр. gemini-3.1-flash-lite, gemini-2.5-flash, gemini-2.5-flash-lite
GEMINI_MODEL=gemini-3.1-flash-lite
DB_PATH=diary.db
# Postgres/Supabase (если задан — используется вместо SQLite). Пример:
# DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
DEFAULT_TZ=Europe/Moscow
TICK_INTERVAL=60
